// ListOnce - Prisma schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------
// Auth (NextAuth)
// -------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  listings      Listing[]
  channelConnections ChannelConnection[]
  notifications InboxNotification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------------------------------
// Listings & channels (MVP)
// -------------------------------------------
model Listing {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos       ListingPhoto      []
  postAttempts PostAttempt       []
}

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String   // local path or S3 URL
  order     Int      @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum ChannelType {
  ebay
  craigslist
  facebook
  offerup
}

model ChannelConnection {
  id        String      @id @default(cuid())
  userId    String
  channel   ChannelType
  // eBay: store OAuth access/refresh from Account or separate token table
  // Craigslist/FB/OfferUp: we do NOT store passwords; extension does assisted posting
  externalId String?   // platform user/item id if needed
  metadata  Json?       // channel-specific non-secret data
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId])
}

enum PostStatus {
  pending
  success
  failed
  assisted   // user will post via extension
}

model PostAttempt {
  id         String     @id @default(cuid())
  listingId  String
  channel    ChannelType
  status     PostStatus @default(pending)
  externalUrl String?    // link to listing on platform
  error      String?    @db.Text
  attemptedAt DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([channel])
}

// -------------------------------------------
// Inbox (email notifications)
// -------------------------------------------
model InboxNotification {
  id         String   @id @default(cuid())
  userId     String
  platform   String   // ebay, craigslist, facebook, offerup
  listingRef String?  // our listing id or external id
  subject    String?  @db.Text
  threadLink String?  @db.Text  // deep-link to conversation on platform
  receivedAt DateTime @default(now())
  read       Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([receivedAt])
}
