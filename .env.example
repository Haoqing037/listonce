# ListOnce – copy to .env and fill in values
# See README for where to obtain each.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/listonce?schema=public"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Optional: OAuth providers (uncomment when configuring)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ---------------------------------------------------------------------------
# eBay API (OAuth + listings)
# ---------------------------------------------------------------------------
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/ebay (or your auth callback route)

# ---------------------------------------------------------------------------
# Craigslist (bulk posting – if applicable)
# ---------------------------------------------------------------------------
# CRAIGSLIST_* – add when implementing; may require paid access

# ---------------------------------------------------------------------------
# File storage (local dev; optional S3 in production)
# ---------------------------------------------------------------------------
# Local: uploads stored in ./uploads (create dir; add to .gitignore)
UPLOAD_DIR="./uploads"
# Optional S3:
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Inbound email (choose one approach for MVP)
# ---------------------------------------------------------------------------
# Option A: Mailgun inbound parse
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_INBOUND_WEBHOOK_SECRET=

# Option B: SendGrid inbound parse
# SENDGRID_INBOUND_PARSE_USER=
# SENDGRID_INBOUND_PARSE_PASS=
# SENDGRID_WEBHOOK_VERIFY_KEY=

# Option C: IMAP polling (fallback)
# IMAP_HOST=imap.gmail.com
# IMAP_USER=
# IMAP_PASS=
# IMAP_MAILBOX=INBOX

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Base URL for webhook links (e.g. https://your-app.vercel.app)
APP_URL="http://localhost:3000"
